rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId
          && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
          && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
          && data.currentStreak is number && data.currentStreak >= 0
          && data.totalWorkouts is number && data.totalWorkouts >= 0
          && (data.lastWorkoutDate == null || data.lastWorkoutDate is timestamp)
          && (data.createdAt == null || data.createdAt is timestamp);
      }

      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); 
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming()) 
        && incoming().keys().hasAll(['uid', 'displayName', 'currentStreak', 'totalWorkouts'])
        && incoming().keys().size() <= 10;
        
      allow update: if isOwner(userId) 
        && isValidUser(incoming()) 
        && (
          // Action: Profile Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])) ||
          // Action: Workout Progress
          (incoming().diff(existing()).affectedKeys().hasOnly(['currentStreak', 'totalWorkouts', 'lastWorkoutDate']))
        )
        && incoming().uid == existing().uid; // Immutable field

      match /memberships/{groupId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(groupId)
          && incoming().keys().hasAll(['joinedAt'])
          && incoming().joinedAt == request.time;
        allow update: if isOwner(userId) && isValidId(groupId);
        allow delete: if isOwner(userId) && isValidId(groupId);
      }
    }

    // Groups (Clans)
    match /groups/{groupId} {
      function isValidGroup(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.createdBy == request.auth.uid
          && data.createdAt is timestamp
          && (data.description == null || (data.description is string && data.description.size() <= 1000))
          && (data.avatar == null || (data.avatar is string && data.avatar.size() <= 1000))
          && (data.memberCount == null || data.memberCount is number);
      }

      allow read, list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(groupId) 
        && isValidGroup(incoming()) 
        && incoming().createdAt == request.time
        && incoming().keys().hasAll(['name', 'createdBy', 'createdAt']);
        
      allow update: if isSignedIn() && isValidId(groupId)
        && (
          // Member count update (Anyone)
          (incoming().diff(existing()).affectedKeys().hasOnly(['memberCount'])) ||
          // Admin update (Creator)
          (existing().createdBy == request.auth.uid && isValidGroup(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'avatar']))
        )
        && incoming().createdBy == existing().createdBy;

      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;
    }

    // Workouts
    match /workouts/{workoutId} {
      function isValidWorkout(data) {
        return data.userId == request.auth.uid
          && data.bodyPart in ['Legs', 'Shoulders', 'Chest', 'Arms', 'Back']
          && data.duration is number && data.duration > 0 && data.duration <= 1440
          && data.intensity is number && data.intensity >= 1 && data.intensity <= 10
          && data.createdAt is timestamp;
      }

      // Updated: Allow public read of workouts for the Community Feed
      allow read, list: if isSignedIn(); 
      
      allow create: if isSignedIn() && isValidWorkout(incoming())
        && incoming().createdAt == request.time
        && incoming().keys().hasAll(['userId', 'bodyPart', 'duration', 'intensity', 'createdAt', 'userName']);
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
